#!/usr/bin/env bash

readonly manifest="$HOME/.projects"
readonly unit_separator=$'\x1f'

session_name() {
    local path="$1"
    local session=${path#$HOME/}
    session=${session//\//-}
    session=${session//[^[:alnum:]_-]/-}
    printf '%s\n' "$session"
}

list_projects() {
    [[ -f "$manifest" ]] || return 1

    local p d session marker

    while IFS= read -r p; do
        [[ -z "$p" || "$p" == \#* ]] && continue

        [[ -d "$p" ]] || {
            printf 'Invalid path in %s: %s\n' "$manifest" "$p" >&2
            continue
        }

        p=$(realpath "$p") || continue

        while IFS= read -r d; do
            session=$(session_name "$d")
            if tmux has-session -t "$session" 2>/dev/null; then
                marker='*'
            else
                marker=' '
            fi
            printf '%s%s%s\n' "$marker" "$unit_separator" "$d"
        done < <(find "$p" -mindepth 1 -maxdepth 1 -type d ! -name '.*')
    done < "$manifest" | sort -u
}

kill_project_session() {
    local line="$1"
    local marker path session

    IFS="$unit_separator" read -r marker path <<< "$line"
    session=$(session_name "$path")
    tmux kill-session -t "$session" 2>/dev/null
}

if [[ "${1:-}" == "--list" ]]; then
    list_projects
    exit 0
fi

if [[ "${1:-}" == "--kill-session" ]]; then
    kill_project_session "$2"
    exit 0
fi

[[ -f "$manifest" ]] || exit 1

script_path=$(printf '%q' "$0")

selection=$(
    list_projects | fzf \
        --header='enter: open/switch | ctrl-x: kill session | * = active session' \
        --delimiter="$unit_separator" \
        --nth=2 \
        --with-nth=1,2 \
        --bind "ctrl-x:execute-silent($script_path --kill-session {})+reload($script_path --list)"
)

[[ -n "$selection" ]] || exit 0

marker=
IFS="$unit_separator" read -r marker selection <<< "$selection"
session=$(session_name "$selection")

if [[ -n "${TMUX:-}" ]]; then
    if tmux has-session -t "$session" 2>/dev/null; then
        tmux switch-client -t "$session"
    else
        tmux new-session -d -s "$session" -c "$selection"
        tmux switch-client -t "$session"
    fi
else
    if tmux has-session -t "$session" 2>/dev/null; then
        tmux attach -t "$session"
    else
        tmux new-session -s "$session" -c "$selection"
    fi
fi
