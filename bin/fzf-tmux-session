#!/usr/bin/env bash

manifest="$HOME/.projects"
[[ ! -f "$manifest" ]] && exit 1

projects=()
while IFS= read -r p; do
    [[ -z "$p" || "$p" == \#* ]] && continue

    p=$(printf '%s' "$p" | envsubst)
    [[ ! -d "$p" ]] && continue

    while IFS= read -r d; do
        projects+=("$d")
    done < <(find "$p" -mindepth 1 -maxdepth 1 -type d ! -name '.*')
done < "$manifest"

selection=$(printf '%s\n' "${projects[@]}" | fzf)
[[ -z "$selection" ]] && exit 0

session=${selection##*/}
session=${session//./-}


if [ -n "$TMUX" ]; then
    if tmux has-session -t "$session" 2>/dev/null; then
        tmux switch-client -t "$session"
    else
        tmux new-session -d -s "$session" -c "$worktree"
        tmux switch-client -t "$session"
    fi
else
    tmux has-session -t "$session" 2>/dev/null && \
        tmux attach -t "$session" || \
        tmux new-session -s "$session" -c "$worktree"
fi
