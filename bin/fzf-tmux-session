#!/usr/bin/env bash

readonly manifest="$HOME/.projects"

session_name() {
    local path="$1"
    local session=${path#$HOME/}
    session=${session//\//-}
    session=${session//[^[:alnum:]_-]/-}
    printf '%s\n' "$session"
}

project_paths() {
    [[ -f "$manifest" ]] || return 1

    local p d

    while IFS= read -r p; do
        [[ -z "$p" || "$p" == \#* ]] && continue

        [[ -d "$p" ]] || {
            printf 'Invalid path in %s: %s\n' "$manifest" "$p" >&2
            continue
        }

        p=$(realpath "$p") || continue

        find "$p" -mindepth 1 -maxdepth 1 -type d ! -name '.*'
    done < "$manifest" | sort -u
}

project_path_by_index() {
    local target="$1"
    local index=0 path

    [[ "$target" =~ ^[0-9]+$ ]] || return 1

    while IFS= read -r path; do
        if [[ "$index" -eq "$target" ]]; then
            printf '%s\n' "$path"
            return 0
        fi
        ((index++))
    done < <(project_paths)

    return 1
}

list_projects() {
    local index=0 path session marker

    while IFS= read -r path; do
        session=$(session_name "$path")
        if tmux has-session -t "$session" 2>/dev/null; then
            marker='*'
        else
            marker=' '
        fi
        printf '%s\t%s\t%s\n' "$index" "$path" "$marker"
        ((index++))
    done < <(project_paths)
}

kill_project_session() {
    local index="$1"
    local path session

    path=$(project_path_by_index "$index") || return 1
    session=$(session_name "$path")
    tmux kill-session -t "$session" 2>/dev/null
}

if [[ "${1:-}" == "--list" ]]; then
    list_projects
    exit 0
fi

if [[ "${1:-}" == "--kill-session" ]]; then
    kill_project_session "$2"
    exit 0
fi

[[ -f "$manifest" ]] || exit 1

script_path=$(printf '%q' "$0")

selection=$(
    list_projects | fzf \
        --header='enter: open/switch | ctrl-x: kill session | * = active session' \
        --delimiter=$'\t' \
        --with-nth=3,2 \
        --bind "ctrl-x:execute-silent($script_path --kill-session {1})+reload($script_path --list)"
)

[[ -n "$selection" ]] || exit 0

selection=${selection#*$'\t'}
selection=${selection%%$'\t'*}
session=$(session_name "$selection")

if [[ -n "${TMUX:-}" ]]; then
    if tmux has-session -t "$session" 2>/dev/null; then
        tmux switch-client -t "$session"
    else
        tmux new-session -d -s "$session" -c "$selection"
        tmux switch-client -t "$session"
    fi
else
    if tmux has-session -t "$session" 2>/dev/null; then
        tmux attach -t "$session"
    else
        tmux new-session -s "$session" -c "$selection"
    fi
fi
