#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "shellwords"

CONFIG = File.expand_path("~/.config/tmux-switch-plus/config")
CURRENT_SESSION_MARKER = "\e[32m●\e[0m"
ACTIVE_SESSION_MARKER = "\e[33m●\e[0m"

def normalize_path(path)
  File.realpath(path)
rescue Errno::ENOENT, Errno::EACCES
  File.expand_path(path)
end

def session_name_slug(parts)
  parts.join("-").gsub(/[^[:alnum:]_-]/, "-")
end

def project_paths
  @project_paths ||= each_project_path.to_a
end

def session_names_by_path
  @session_names_by_path ||= begin
    normalized_parts = project_paths.to_h do |path|
      [path, normalize_path(path).split("/").reject(&:empty?)]
    end

    normalized_parts.each_with_object({}) do |(path, parts), names|
      name = nil

      1.upto(parts.length) do |count|
        candidate = session_name_slug(parts.last(count))
        next if candidate.empty?

        conflict = normalized_parts.any? do |other_path, other_parts|
          next false if other_path == path

          session_name_slug(other_parts.last(count)) == candidate
        end

        unless conflict
          name = candidate
          break
        end
      end

      name ||= "#{session_name_slug(parts)}-#{Digest::SHA1.hexdigest(normalize_path(path))[0, 8]}"
      names[path] = name
    end
  end
end

def session_name(path)
  session_names_by_path[path] || begin
    normalized = normalize_path(path)
    parts = normalized.split("/").reject(&:empty?)
    "#{session_name_slug(parts.last(1))}-#{Digest::SHA1.hexdigest(normalized)[0, 8]}"
  end
end

def display_path(path)
  normalized = normalize_path(path)
  home = Dir.home

  return "~" if normalized == home
  return normalized.sub("#{home}/", "~/") if normalized.start_with?("#{home}/")

  normalized
end

def warn_invalid_config_path(entry)
  warn "invalid path in #{CONFIG}: #{entry}"
end

def each_project_path
  return enum_for(__method__) unless block_given?
  return unless File.file?(CONFIG)

  paths = []
  config_dir = File.dirname(CONFIG)

  File.foreach(CONFIG, chomp: true) do |entry|
    next if entry.empty? || entry.start_with?("#")

    begin
      root = File.realpath(File.expand_path(entry, config_dir))
      Dir.each_child(root) do |child|
        next if child.start_with?(".")

        path = File.join(root, child)
        paths << path if File.directory?(path)
      end
    rescue Errno::ENOENT, Errno::EACCES
      warn_invalid_config_path(entry)
    end
  end

  paths.sort.uniq.each { |path| yield path }
end

def project_path_by_index(target)
  return unless target.to_s.match?(/\A\d+\z/)

  target_index = target.to_i
  project_paths[target_index]
end

def tmux_session_exists?(session)
  system("tmux", "has-session", "-t", session, out: File::NULL, err: File::NULL)
end

def current_tmux_session
  @current_tmux_session ||= begin
    if ENV.key?("TMUX")
      session = IO.popen(["tmux", "display-message", "-p", "#S"], err: File::NULL, &:read).to_s.strip
      session.empty? ? nil : session
    end
  rescue Errno::ENOENT
    nil
  end
end

def project_row(index, path, include_hidden_path: false)
  session = session_name(path)
  marker = if !tmux_session_exists?(session)
    " "
  elsif session == current_tmux_session
    CURRENT_SESSION_MARKER
  else
    ACTIVE_SESSION_MARKER
  end

  fields = [index]
  fields << path if include_hidden_path
  fields << display_path(path)
  fields << marker
  fields.join("\t")
end

def list_projects(include_hidden_path: false)
  project_paths.each_with_index do |path, index|
    puts project_row(index, path, include_hidden_path: include_hidden_path)
  end
end

def kill_project_session(index)
  path = project_path_by_index(index)
  return false unless path

  system("tmux", "kill-session", "-t", session_name(path), out: File::NULL, err: File::NULL)
end

def preview_project(index)
  path = project_path_by_index(index)
  return false unless path

  session = session_name(path)

  puts "project  #{display_path(path)}"
  puts "session  #{session}"
  puts

  unless tmux_session_exists?(session)
    puts "no session"
    return true
  end

  exec(
    "tmux",
    "list-windows",
    "-t",
    session,
    "-F",
    '#{?window_active,>, } #{window_index}: #{window_name}#{window_flags}  #{window_panes} panes'
  )
end

def select_project(script_path)
  command = [
    "fzf",
    "--ansi",
    "--header=enter: open/switch | ctrl-x: kill session",
    "--delimiter=\t",
    "--with-nth=4,3",
    "--preview",
    "#{script_path} --preview {1}",
    "--preview-window",
    "right:60%",
    "--bind",
    "ctrl-x:execute-silent(#{script_path} --kill-session {1})+reload(#{script_path} --list-fzf)"
  ]

  IO.popen(command, "r+") do |io|
    project_paths.each_with_index do |path, index|
      io.puts project_row(index, path, include_hidden_path: true)
    end
    io.close_write
    io.read
  end
rescue Errno::ENOENT
  warn "fzf is required"
  nil
end

def activate_selection(selection)
  return if selection.nil? || selection.empty?

  _, path, = selection.split("\t", 3)
  return unless path

  session = session_name(path)
  session_exists = tmux_session_exists?(session)

  if ENV.key?("TMUX")
    unless session_exists
      system("tmux", "new-session", "-d", "-s", session, "-c", path)
    end
    system("tmux", "switch-client", "-t", session)
  elsif session_exists
    exec("tmux", "attach", "-t", session)
  else
    exec("tmux", "new-session", "-s", session, "-c", path)
  end
end

command = ARGV.shift

case command
when "--list"
  list_projects
when "--list-fzf"
  list_projects(include_hidden_path: true)
when "--kill-session"
  exit(kill_project_session(ARGV.shift) ? 0 : 1)
when "--preview"
  exit(preview_project(ARGV.shift) ? 0 : 1)
else
  exit 1 unless File.file?(CONFIG)

  script_path = Shellwords.escape(File.expand_path($PROGRAM_NAME))
  activate_selection(select_project(script_path))
end
