#!/usr/bin/env bash

open_worktree() {
    local repo
    local session
    local worktree
    local wt


    worktree=$(git worktree list | awk '{print $1}' | fzf)
    if [ -z "$worktree" ]; then
        echo -e "no git worktrees found"
        return
    fi

    repo=$(cd "$worktree" && basename -s .git "$(git remote get-url origin)")
    worktree_name=$(basename "$worktree")

    session=$(echo "${repo}-${worktree_name}" | tr -c "a-zA-Z0-9_-" "_")

    if [ -n "$TMUX" ]; then
        if tmux has-session -t "$session" 2>/dev/null; then
            tmux switch-client -t "$session"
        else
            tmux new-session -d -s "$session" -c "$worktree"
            tmux switch-client -t "$session"
        fi
    else
        tmux has-session -t "$session" 2>/dev/null && \
            tmux attach -t "$session" || \
            tmux new-session -s "$session" -c "$worktree"
    fi
}

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "not in a git repository"
    exit 1
fi

open_worktree
